	"item": [
		{
			"name": "Add School",
			"request": {
				"method": "POST",
				"header": [
					{
						"key": "Content-Type",
						"value": "application/json"
					}
				],
				"body": {
					"mode": "raw",
					"raw": "{\n    \"name\": \"Example School\",\n    \"address\": \"123 Education Lane, Learning City\",\n    \"latitude\": 28.6139,\n    \"longitude\": 77.2090\n}"
				},
				"url": {
					"raw": "{{base_url}}/addSchool",
					"host": [
						"{{base_url}}"
					],
					"path": [
						"addSchool"
					]
				},
				"description": "Adds a new school to the database after validation."
			},
			"response": []
		},
		{
			"name": "List Schools",
			"request": {
				"method": "GET",
				"header": [],
				"url": {
					"raw": "{{base_url}}/listSchools?latitude=28.6139&longitude=77.2090",
					"host": [
						"{{base_url}}"
					],
					"path": [
						"listSchools"
					],
					"query": [
						{
							"key": "latitude",
							"value": "28.6139",
							"description": "User's current latitude"
						},
						{
							"key": "longitude",
							"value": "77.2090",
							"description": "User's current longitude"
						}
					]
				},
				"description": "Retrieves all schools and sorts them by distance from the provided coordinates."
			},
			"response": []
		}
